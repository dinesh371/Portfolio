<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="theme-color" content="#050816">
<title>Dinesh Tankala — IT Infrastructure Manager</title>
<meta name="description" content="Dinesh Tankala — IT Infrastructure Manager & Cybersecurity Professional. Microsoft 365, Azure, Okta, networking, ITSM & change management. Building secure, scalable, intelligent digital infrastructure.">
<meta property="og:title" content="Dinesh Tankala — IT Infrastructure Manager">
<meta property="og:description" content="Building secure, scalable & intelligent digital infrastructure.">
<meta property="og:type" content="website">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --bg:#050816;--bg-2:#0F172A;--blue:#3B82F6;--purple:#7C3AED;--cyan:#06B6D4;--pink:#EC4899;
    --white:#FFFFFF;--text:#EAECF5;--muted:#8A93B2;--muted-2:#5a6485;
    --line:rgba(255,255,255,.09);--glass:rgba(255,255,255,.045);--glass-2:rgba(255,255,255,.07);
    --radius:22px;--mono:'JetBrains Mono',monospace;--sans:'Inter',sans-serif;--display:'Space Grotesk',sans-serif;
  }
  *{margin:0;padding:0;box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{background:var(--bg);color:var(--text);font-family:var(--sans);line-height:1.65;overflow-x:hidden;position:relative;}
  a{color:inherit;text-decoration:none;}
  img{max-width:100%;display:block;}
  ::selection{background:var(--purple);color:#fff;}
  .wrap{max-width:1160px;margin:0 auto;padding:0 28px;position:relative;z-index:2;}

  .aurora{position:fixed;inset:0;z-index:0;overflow:hidden;pointer-events:none;}
  .orb{position:absolute;border-radius:50%;filter:blur(90px);opacity:.55;will-change:transform;}
  .orb.b1{width:520px;height:520px;background:radial-gradient(circle,var(--purple),transparent 70%);top:-120px;left:-100px;animation:float1 18s ease-in-out infinite;}
  .orb.b2{width:460px;height:460px;background:radial-gradient(circle,var(--blue),transparent 70%);top:20%;right:-140px;animation:float2 22s ease-in-out infinite;}
  .orb.b3{width:420px;height:420px;background:radial-gradient(circle,var(--cyan),transparent 70%);bottom:-120px;left:20%;animation:float3 20s ease-in-out infinite;}
  .orb.b4{width:360px;height:360px;background:radial-gradient(circle,var(--pink),transparent 70%);bottom:10%;right:15%;opacity:.35;animation:float1 26s ease-in-out infinite;}
  @keyframes float1{0%,100%{transform:translate(0,0);}50%{transform:translate(60px,50px);}}
  @keyframes float2{0%,100%{transform:translate(0,0);}50%{transform:translate(-70px,40px);}}
  @keyframes float3{0%,100%{transform:translate(0,0);}50%{transform:translate(40px,-50px);}}
  #net{position:fixed;inset:0;z-index:1;pointer-events:none;opacity:.5;}
  body::after{content:'';position:fixed;inset:0;z-index:1;pointer-events:none;background:radial-gradient(circle at 50% 0%,transparent 40%,var(--bg) 88%);}
  .spotlight{position:fixed;width:520px;height:520px;border-radius:50%;z-index:1;pointer-events:none;background:radial-gradient(circle,rgba(124,58,237,.10),transparent 65%);transform:translate(-50%,-50%);transition:opacity .3s;opacity:0;}

  .cursor-dot,.cursor-ring{position:fixed;top:0;left:0;pointer-events:none;z-index:9999;border-radius:50%;transform:translate(-50%,-50%);}
  .cursor-dot{width:6px;height:6px;background:var(--cyan);}
  .cursor-ring{width:32px;height:32px;border:1.5px solid rgba(255,255,255,.4);transition:width .2s,height .2s,border-color .2s,background .2s;}
  .cursor-ring.hover{width:56px;height:56px;border-color:var(--cyan);background:rgba(6,182,212,.08);}
  body.cursor-on,body.cursor-on a,body.cursor-on button{cursor:none;}

  .progress{position:fixed;top:0;left:0;height:3px;width:0;z-index:60;background:linear-gradient(90deg,var(--blue),var(--purple),var(--cyan));box-shadow:0 0 10px rgba(124,58,237,.6);}

  header{position:fixed;top:16px;left:0;right:0;z-index:55;transition:top .3s;}
  nav{max-width:1160px;margin:0 auto;padding:12px 22px;display:flex;align-items:center;justify-content:space-between;background:var(--glass);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);border:1px solid var(--line);border-radius:100px;box-shadow:0 8px 32px -12px rgba(0,0,0,.5);margin-left:24px;margin-right:24px;}
  .logo{font-family:var(--display);font-weight:700;font-size:16px;display:flex;align-items:center;gap:9px;}
  .logo .mark{width:26px;height:26px;border-radius:8px;background:linear-gradient(135deg,var(--blue),var(--purple),var(--cyan));display:flex;align-items:center;justify-content:center;font-size:12px;color:#fff;font-weight:700;}
  .navlinks{display:flex;gap:26px;font-size:13.5px;color:var(--muted);}
  .navlinks a{transition:color .22s;position:relative;}
  .navlinks a:hover,.navlinks a.active{color:var(--white);}
  .nav-right{display:flex;align-items:center;gap:12px;}
  .theme-btn{width:36px;height:36px;border-radius:50%;border:1px solid var(--line);background:var(--glass);color:var(--text);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:15px;transition:border-color .25s;}
  .theme-btn:hover{border-color:var(--cyan);}
  .nav-cta{font-size:13px;padding:9px 18px;border-radius:100px;background:linear-gradient(135deg,var(--blue),var(--purple));color:#fff;font-weight:600;transition:filter .25s;}
  .nav-cta:hover{filter:brightness(1.12);}
  .navburger{display:none;flex-direction:column;gap:4px;background:none;border:none;cursor:pointer;padding:6px;}
  .navburger span{width:20px;height:2px;background:var(--text);border-radius:2px;}

  .btn{font-size:14px;padding:14px 26px;border-radius:100px;border:1px solid var(--line);display:inline-flex;align-items:center;gap:9px;transition:transform .2s,border-color .25s,background .25s,box-shadow .25s;position:relative;overflow:hidden;font-weight:500;}
  .btn.grad{background:linear-gradient(135deg,var(--blue),var(--purple),var(--cyan));background-size:180% 180%;color:#fff;border-color:transparent;font-weight:600;animation:gradShift 6s ease infinite;}
  @keyframes gradShift{0%,100%{background-position:0% 50%;}50%{background-position:100% 50%;}}
  .btn.grad:hover{box-shadow:0 14px 34px -12px rgba(124,58,237,.6);}
  .btn.glass{background:var(--glass);backdrop-filter:blur(10px);}
  .btn.glass:hover{border-color:var(--cyan);background:var(--glass-2);}

  section{padding:120px 0;position:relative;}
  .eyebrow{font-family:var(--mono);font-size:12.5px;letter-spacing:.14em;text-transform:uppercase;color:transparent;background:linear-gradient(90deg,var(--cyan),var(--purple));-webkit-background-clip:text;background-clip:text;display:inline-flex;align-items:center;gap:9px;margin-bottom:18px;}
  .eyebrow::before{content:'';width:26px;height:1px;background:linear-gradient(90deg,var(--cyan),var(--purple));}
  .sec-title{font-family:var(--display);font-weight:700;font-size:clamp(2rem,4vw,3rem);letter-spacing:-.02em;line-height:1.08;margin-bottom:18px;}
  .sec-title .grad,.about-lead .grad,h1.name .grad{background:linear-gradient(120deg,var(--blue),var(--purple) 45%,var(--cyan));-webkit-background-clip:text;background-clip:text;color:transparent;}
  .sec-sub{color:var(--muted);max-width:60ch;font-size:1.02rem;margin-bottom:64px;}

  .glass-card{background:var(--glass);backdrop-filter:blur(18px);-webkit-backdrop-filter:blur(18px);border:1px solid var(--line);border-radius:var(--radius);position:relative;overflow:hidden;transition:transform .3s,border-color .3s,box-shadow .3s;}
  .glass-card::before{content:'';position:absolute;inset:0;border-radius:var(--radius);padding:1px;pointer-events:none;opacity:0;transition:opacity .3s;background:linear-gradient(135deg,var(--blue),var(--purple),var(--cyan));-webkit-mask:linear-gradient(#000 0 0) content-box,linear-gradient(#000 0 0);-webkit-mask-composite:xor;mask-composite:exclude;}
  .glass-card:hover{transform:translateY(-6px);}
  .glass-card:hover::before{opacity:.8;}

  .hero{min-height:100vh;display:flex;align-items:center;padding-top:120px;}
  .hero-grid{display:grid;grid-template-columns:1.15fr .85fr;gap:56px;align-items:center;}
  .status-pill{display:inline-flex;align-items:center;gap:8px;font-family:var(--mono);font-size:12px;color:var(--cyan);border:1px solid rgba(6,182,212,.3);background:rgba(6,182,212,.07);padding:7px 14px;border-radius:100px;margin-bottom:26px;}
  .status-pill .dot{width:6px;height:6px;border-radius:50%;background:#34d399;box-shadow:0 0 8px #34d399;animation:blink 2s infinite;}
  @keyframes blink{0%,100%{opacity:1;}50%{opacity:.3;}}
  h1.name{font-family:var(--display);font-weight:700;font-size:clamp(2.8rem,7vw,5rem);line-height:1;letter-spacing:-.03em;}
  .rotator{height:2.4em;margin-top:14px;font-family:var(--display);font-weight:600;font-size:clamp(1.1rem,2.4vw,1.7rem);overflow:hidden;position:relative;}
  .rotator .r-item{position:absolute;left:0;width:100%;opacity:0;transform:translateY(100%);transition:opacity .5s,transform .5s;color:transparent;background:linear-gradient(90deg,var(--cyan),var(--blue));-webkit-background-clip:text;background-clip:text;}
  .rotator .r-item.on{opacity:1;transform:translateY(0);}
  .rotator .r-item.off{opacity:0;transform:translateY(-100%);}
  .headline{font-family:var(--display);font-weight:500;font-size:clamp(1.15rem,2vw,1.5rem);color:var(--text);margin-top:22px;letter-spacing:-.01em;max-width:20ch;}
  .typed{color:var(--muted);margin-top:20px;font-size:1.02rem;max-width:52ch;min-height:3.2em;}
  .typed .caret{display:inline-block;width:2px;height:1.05em;background:var(--cyan);margin-left:2px;vertical-align:-2px;animation:caret 1s step-end infinite;}
  @keyframes caret{50%{opacity:0;}}
  .hero-cta{display:flex;gap:14px;flex-wrap:wrap;margin-top:38px;}

  .avatar-wrap{display:flex;justify-content:center;perspective:1000px;}
  .avatar{position:relative;width:min(340px,80vw);aspect-ratio:1;border-radius:28px;padding:3px;will-change:transform;transform-style:preserve-3d;transition:transform .18s ease-out;}
  .avatar::before{content:'';position:absolute;inset:-2px;border-radius:30px;z-index:-1;background:conic-gradient(from 0deg,var(--blue),var(--purple),var(--cyan),var(--pink),var(--blue));animation:spin 6s linear infinite;filter:blur(9px);opacity:.9;}
  @keyframes spin{to{transform:rotate(360deg);}}
  .avatar img{width:100%;height:100%;object-fit:cover;object-position:50% 20%;border-radius:26px;display:block;}
  .avatar .ring2{position:absolute;inset:-2px;border-radius:30px;padding:2px;background:conic-gradient(from 180deg,var(--cyan),var(--purple),var(--blue),var(--cyan));-webkit-mask:linear-gradient(#000 0 0) content-box,linear-gradient(#000 0 0);-webkit-mask-composite:xor;mask-composite:exclude;animation:spin 8s linear infinite reverse;}
  .float-badge{position:absolute;background:var(--glass-2);backdrop-filter:blur(12px);border:1px solid var(--line);border-radius:14px;padding:10px 14px;font-size:12px;display:flex;align-items:center;gap:8px;box-shadow:0 10px 30px -12px rgba(0,0,0,.6);}
  .float-badge .ic{font-size:16px;}
  .fb-1{top:8%;left:-8%;animation:bob 5s ease-in-out infinite;}
  .fb-2{bottom:12%;right:-10%;animation:bob 6s ease-in-out infinite .5s;}
  @keyframes bob{0%,100%{transform:translateY(0);}50%{transform:translateY(-12px);}}

  .stats{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--line);border:1px solid var(--line);border-radius:var(--radius);overflow:hidden;margin-top:90px;}
  .stat{background:rgba(15,23,42,.5);backdrop-filter:blur(12px);padding:28px 24px;text-align:center;}
  .stat .n{font-family:var(--display);font-weight:700;font-size:2.1rem;background:linear-gradient(120deg,var(--cyan),var(--purple));-webkit-background-clip:text;background-clip:text;color:transparent;}
  .stat .l{font-size:12.5px;color:var(--muted);margin-top:4px;}

  .about-grid{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:start;}
  .about-lead{font-family:var(--display);font-weight:500;font-size:1.4rem;line-height:1.5;letter-spacing:-.01em;}
  .about-body p{color:var(--muted);margin-bottom:16px;}
  .about-facts{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:26px;}
  .fact{padding:16px 18px;border:1px solid var(--line);border-radius:16px;background:var(--glass);}
  .fact .k{font-family:var(--mono);font-size:11px;color:var(--cyan);text-transform:uppercase;letter-spacing:.06em;}
  .fact .v{font-size:.95rem;margin-top:4px;}

  .skills-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(170px,1fr));gap:16px;}
  .skill{padding:20px 18px;border-radius:16px;border:1px solid var(--line);background:var(--glass);display:flex;flex-direction:column;gap:10px;transition:transform .25s,border-color .25s,background .25s;}
  .skill:hover{transform:translateY(-5px);border-color:rgba(6,182,212,.4);background:var(--glass-2);}
  .skill .ic{width:40px;height:40px;border-radius:11px;display:flex;align-items:center;justify-content:center;font-size:19px;background:linear-gradient(135deg,rgba(59,130,246,.18),rgba(124,58,237,.18));border:1px solid var(--line);}
  .skill .nm{font-weight:600;font-size:.95rem;}
  .skill .bar{height:4px;border-radius:4px;background:rgba(255,255,255,.08);overflow:hidden;}
  .skill .bar i{display:block;height:100%;width:0;border-radius:4px;background:linear-gradient(90deg,var(--cyan),var(--purple));transition:width 1s ease;}

  .timeline{position:relative;padding-left:34px;}
  .timeline::before{content:'';position:absolute;left:6px;top:6px;bottom:6px;width:2px;background:linear-gradient(var(--purple),var(--cyan),transparent);}
  .tl-item{position:relative;padding-bottom:44px;}
  .tl-item:last-child{padding-bottom:0;}
  .tl-item::before{content:'';position:absolute;left:-34px;top:5px;width:14px;height:14px;border-radius:50%;background:var(--bg);border:2px solid var(--cyan);box-shadow:0 0 12px rgba(6,182,212,.6);}
  .tl-item.past::before{border-color:var(--muted-2);box-shadow:none;}
  .tl-top{display:flex;flex-wrap:wrap;justify-content:space-between;gap:8px;align-items:baseline;}
  .tl-role{font-family:var(--display);font-weight:600;font-size:1.2rem;}
  .tl-org{color:var(--cyan);font-size:.92rem;}
  .tl-time{font-family:var(--mono);font-size:12px;color:var(--muted);}
  .tl-item ul{list-style:none;margin-top:14px;}
  .tl-item li{position:relative;padding-left:20px;color:var(--muted);font-size:.93rem;margin-bottom:8px;max-width:72ch;}
  .tl-item li::before{content:'▹';position:absolute;left:0;color:var(--purple);}
  .tl-tags{display:flex;flex-wrap:wrap;gap:7px;margin-top:14px;}
  .tl-tag{font-family:var(--mono);font-size:11px;color:var(--muted);border:1px solid var(--line);padding:3px 10px;border-radius:100px;}

  .grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;}
  .grid-2{display:grid;grid-template-columns:repeat(2,1fr);gap:18px;}

  .cert{padding:24px;}
  .cert .badge{width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:20px;margin-bottom:16px;background:linear-gradient(135deg,rgba(6,182,212,.2),rgba(124,58,237,.2));border:1px solid var(--line);}
  .cert h3{font-family:var(--display);font-size:1rem;font-weight:600;margin-bottom:6px;}
  .cert .issuer{color:var(--cyan);font-family:var(--mono);font-size:11.5px;}
  .cert .meta{color:var(--muted-2);font-family:var(--mono);font-size:11px;margin-top:8px;}

  .service{padding:28px 24px;}
  .service .ic{width:46px;height:46px;border-radius:13px;display:flex;align-items:center;justify-content:center;font-size:21px;margin-bottom:18px;background:linear-gradient(135deg,rgba(59,130,246,.18),rgba(236,72,153,.18));border:1px solid var(--line);}
  .service h3{font-family:var(--display);font-size:1.15rem;font-weight:600;margin-bottom:10px;}
  .service p{color:var(--muted);font-size:.93rem;}

  .project{padding:0;display:flex;flex-direction:column;}
  .project .preview{aspect-ratio:16/10;position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#0b1226,#131c3a);}
  .project .preview .glyph{font-size:3.4rem;filter:drop-shadow(0 6px 18px rgba(6,182,212,.4));transition:transform .4s;z-index:1;}
  .project:hover .preview .glyph{transform:scale(1.12) rotate(-4deg);}
  .project .preview::after{content:'';position:absolute;inset:0;background:radial-gradient(circle at 70% 20%,rgba(124,58,237,.35),transparent 60%);}
  .project .pv-tags{position:absolute;bottom:12px;left:12px;z-index:2;display:flex;gap:6px;flex-wrap:wrap;}
  .project .pv-tags span{font-family:var(--mono);font-size:10px;background:rgba(5,8,22,.7);backdrop-filter:blur(6px);border:1px solid var(--line);padding:3px 9px;border-radius:100px;color:var(--text);}
  .project .pbody{padding:22px 24px;flex:1;display:flex;flex-direction:column;}
  .project h3{font-family:var(--display);font-size:1.15rem;font-weight:600;margin-bottom:8px;}
  .project .pdesc{color:var(--muted);font-size:.92rem;flex:1;}
  .project .metrics{display:flex;gap:20px;margin-top:18px;padding-top:16px;border-top:1px solid var(--line);}
  .project .metric .mn{font-family:var(--display);font-weight:700;font-size:1.25rem;background:linear-gradient(120deg,var(--cyan),var(--purple));-webkit-background-clip:text;background-clip:text;color:transparent;}
  .project .metric .ml{font-size:11px;color:var(--muted);}

  .video-shell{position:relative;border-radius:var(--radius);overflow:hidden;border:1px solid var(--line);aspect-ratio:16/9;background:#0b1020;box-shadow:0 30px 80px -30px rgba(0,0,0,.7);}
  .video-shell video{width:100%;height:100%;object-fit:cover;display:block;}
  .video-poster{position:absolute;inset:0;background-size:cover;background-position:50% 22%;}
  .video-poster::after{content:'';position:absolute;inset:0;background:linear-gradient(180deg,rgba(5,8,22,.35),rgba(5,8,22,.75));}
  .play-btn{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);z-index:3;width:84px;height:84px;border-radius:50%;border:none;cursor:pointer;background:linear-gradient(135deg,var(--blue),var(--purple));color:#fff;font-size:26px;display:flex;align-items:center;justify-content:center;animation:ring 2.4s infinite;}
  @keyframes ring{0%{box-shadow:0 0 0 0 rgba(124,58,237,.5);}70%{box-shadow:0 0 0 24px rgba(124,58,237,0);}100%{box-shadow:0 0 0 0 rgba(124,58,237,0);}}
  .video-note{position:absolute;bottom:16px;left:16px;z-index:3;font-family:var(--mono);font-size:12px;color:var(--text);background:rgba(5,8,22,.7);backdrop-filter:blur(6px);padding:7px 12px;border-radius:10px;border:1px solid var(--line);}

  .quote{padding:28px;}
  .quote p{font-size:1.02rem;line-height:1.6;margin-bottom:20px;}
  .quote .by{display:flex;align-items:center;gap:12px;}
  .quote .by .av{width:38px;height:38px;border-radius:50%;background:linear-gradient(135deg,var(--purple),var(--cyan));display:flex;align-items:center;justify-content:center;font-weight:700;font-size:13px;color:#fff;}
  .quote .by .nm{font-weight:600;font-size:.92rem;}
  .quote .by .rl{color:var(--muted);font-size:.8rem;}
  .note-tag{font-family:var(--mono);font-size:11px;color:var(--muted-2);border:1px dashed var(--line);padding:2px 8px;border-radius:6px;margin-left:8px;vertical-align:middle;}

  .marquee{border-top:1px solid var(--line);border-bottom:1px solid var(--line);padding:26px 0;overflow:hidden;white-space:nowrap;}
  .mtrack{display:inline-flex;animation:scroll 30s linear infinite;}
  .mtrack span{font-family:var(--display);font-size:1.15rem;color:var(--muted-2);display:inline-flex;align-items:center;}
  .mtrack span b{color:var(--text);font-weight:500;padding:0 24px;}
  .mtrack span i{color:var(--cyan);font-style:normal;}
  @keyframes scroll{to{transform:translateX(-50%);}}

  .contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:start;}
  .form-card{padding:34px;}
  .field{margin-bottom:16px;}
  .field label{font-family:var(--mono);font-size:11.5px;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;display:block;margin-bottom:7px;}
  .field input,.field textarea{width:100%;background:rgba(255,255,255,.03);border:1px solid var(--line);border-radius:12px;padding:13px 15px;color:var(--text);font-family:var(--sans);font-size:.95rem;transition:border-color .25s,background .25s;}
  .field input:focus,.field textarea:focus{outline:none;border-color:var(--cyan);background:rgba(6,182,212,.05);}
  .field textarea{resize:vertical;min-height:110px;}
  .channels{display:flex;flex-direction:column;gap:12px;}
  .channel{display:flex;align-items:center;gap:16px;padding:18px 20px;border:1px solid var(--line);border-radius:16px;background:var(--glass);transition:transform .25s,border-color .25s,background .25s;}
  .channel:hover{transform:translateX(6px);border-color:rgba(6,182,212,.4);background:var(--glass-2);}
